<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PandaToken 控制面板</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            color: #e0e0e0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh; padding: 20px;
        }
        .container { max-width: 1200px; margin: 0 auto; }
        h1 { text-align: center; color: #e94560; margin-bottom: 10px; font-size: 2em; text-shadow: 0 0 20px rgba(233,69,96,0.5); }
        .subtitle { text-align: center; color: #888; margin-bottom: 30px; }
        
        .top-bar {
            background: rgba(255,255,255,0.05); border-radius: 15px; padding: 20px;
            margin-bottom: 20px; border: 1px solid rgba(255,255,255,0.1);
            display: flex; flex-wrap: wrap; gap: 15px; align-items: center; justify-content: space-between;
        }
        .wallet-info { display: flex; gap: 15px; align-items: center; flex-wrap: wrap; }
        .wallet-addr { 
            background: rgba(233,69,96,0.2); padding: 8px 15px; border-radius: 20px;
            font-family: monospace; font-size: 14px; color: #e94560;
        }
        .btn {
            padding: 10px 20px; border: none; border-radius: 8px; cursor: pointer;
            font-size: 14px; font-weight: 600; transition: all 0.3s; color: white;
        }
        .btn:hover { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(0,0,0,0.3); }
        .btn-primary { background: linear-gradient(135deg, #e94560, #c23152); }
        .btn-success { background: linear-gradient(135deg, #0f9b0f, #0b7a0b); }
        .btn-warning { background: linear-gradient(135deg, #f2994a, #f2c94c); color: #000; }
        .btn-danger { background: linear-gradient(135deg, #cb2d3e, #ef473a); }
        .btn-info { background: linear-gradient(135deg, #36d1dc, #5b86e5); }
        .btn-sm { padding: 5px 12px; font-size: 12px; }

        .tabs {
            display: flex; gap: 5px; flex-wrap: wrap; margin-bottom: 20px;
            background: rgba(255,255,255,0.05); border-radius: 12px; padding: 5px;
        }
        .tab {
            padding: 12px 20px; border-radius: 8px; cursor: pointer; font-size: 14px;
            transition: all 0.3s; color: #aaa; border: none; background: transparent;
        }
        .tab:hover { color: white; background: rgba(255,255,255,0.1); }
        .tab.active { background: #e94560; color: white; font-weight: bold; }

        .panel {
            background: rgba(255,255,255,0.05); border-radius: 15px; padding: 25px;
            margin-bottom: 20px; border: 1px solid rgba(255,255,255,0.1);
            display: none;
        }
        .panel.active { display: block; }

        .section-title {
            font-size: 1.3em; color: #e94560; margin-bottom: 20px; padding-bottom: 10px;
            border-bottom: 2px solid rgba(233,69,96,0.3);
        }
        .form-group { margin-bottom: 15px; }
        .form-group label { display: block; margin-bottom: 5px; color: #ccc; font-size: 13px; }
        .form-group input, .form-group select {
            width: 100%; padding: 10px 15px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.2);
            background: rgba(0,0,0,0.3); color: white; font-size: 14px;
        }
        .form-group input:focus { outline: none; border-color: #e94560; }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        .form-row-4 { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 15px; }

        .info-card {
            background: rgba(0,0,0,0.3); border-radius: 10px; padding: 15px; margin-bottom: 10px;
            border: 1px solid rgba(255,255,255,0.1);
        }
        .info-row { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
        .info-label { color: #888; }
        .info-value { color: #e0e0e0; font-weight: bold; }

        .switch-group { display: flex; gap: 20px; flex-wrap: wrap; margin: 15px 0; }
        .switch-item {
            display: flex; align-items: center; gap: 10px; padding: 10px 15px;
            background: rgba(0,0,0,0.3); border-radius: 8px; cursor: pointer; transition: all 0.3s;
        }
        .switch-item.on { background: rgba(233,69,96,0.3); border: 1px solid #e94560; }
        .switch-dot {
            width: 20px; height: 20px; border-radius: 50%; background: #555;
            transition: all 0.3s;
        }
        .switch-item.on .switch-dot { background: #e94560; box-shadow: 0 0 10px #e94560; }

        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th, td { padding: 10px; text-align: left; border-bottom: 1px solid rgba(255,255,255,0.1); }
        th { color: #e94560; font-size: 12px; text-transform: uppercase; }
        td { font-size: 13px; }

        .badge {
            padding: 3px 10px; border-radius: 12px; font-size: 11px; font-weight: bold;
        }
        .badge-on { background: rgba(15,155,15,0.3); color: #4caf50; }
        .badge-off { background: rgba(239,71,58,0.3); color: #ef473a; }

        .toast {
            position: fixed; top: 20px; right: 20px; padding: 15px 25px; border-radius: 10px;
            color: white; font-weight: bold; z-index: 1000; animation: slideIn 0.3s ease;
        }
        .toast-success { background: #0f9b0f; }
        .toast-error { background: #ef473a; }
        @keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }

        .quick-actions { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 20px; }
        .convert-box {
            background: rgba(0,0,0,0.3); border-radius: 10px; padding: 20px; margin-top: 15px;
        }
        .convert-result {
            font-family: monospace; background: rgba(0,0,0,0.5); padding: 10px;
            border-radius: 5px; margin-top: 5px; word-break: break-all; font-size: 13px;
        }
        
        @media (max-width: 768px) {
            .form-row, .form-row-4 { grid-template-columns: 1fr; }
            .wallet-info { flex-direction: column; }
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>🐼 PandaToken 控制面板</h1>
        <p class="subtitle">连接MetaMask · 实时数据 · 一键管理</p>

        <!-- 顶部连接栏 -->
        <div class="top-bar">
            <div class="wallet-info">
                <span style="color:#888;">钱包:</span>
                <span class="wallet-addr" id="walletAddress">未连接</span>
                <span id="ownerBadge" style="display:none;" class="badge badge
